#!/usr/bin/env python3
"""clankbox: run opencode inside a reusable podman container bound to the cwd."""

from __future__ import annotations

from contextlib import contextmanager
import fcntl
import hashlib
import json
import os
import re
import shutil
import stat
import subprocess
import sys
from pathlib import Path
from typing import Iterator, NoReturn

IMAGE = "localhost/clankbox:latest"
LABEL_KEY = "clankbox"
LABEL_WORKDIR = "clankbox.workdir"
LABEL_NVIDIA = "clankbox.nvidia"
LABEL_X11 = "clankbox.x11"
LABEL_SCHEMA = "clankbox.schema"
SCHEMA_VERSION = "2"
SCRIPT_PATH = Path(__file__).resolve()
SCRIPT_DIR = SCRIPT_PATH.parent
X11_SOCKET_DIR = Path("/tmp/.X11-unix")
WSLG_DIR = Path("/mnt/wslg")


def resource_root() -> Path:
    """Directory containing Dockerfile and artifacts.json."""
    env = os.environ.get("CLANKBOX_ROOT")
    if env:
        root = Path(env).expanduser().resolve()
        if not (root / "Dockerfile").is_file():
            die(f"CLANKBOX_ROOT={root} has no Dockerfile")
        if not (root / "artifacts.json").is_file():
            die(f"CLANKBOX_ROOT={root} has no artifacts.json")
        return root
    if (SCRIPT_DIR / "Dockerfile").is_file() and (
        SCRIPT_DIR / "artifacts.json"
    ).is_file():
        return SCRIPT_DIR
    die(
        "cannot find clankbox resources (Dockerfile, artifacts.json). "
        "Run from a full checkout, or set CLANKBOX_ROOT to that checkout"
    )


def artifacts_path() -> Path:
    return resource_root() / "artifacts.json"

