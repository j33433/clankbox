PASSTHROUGH_ENV = (
    "GITHUB_TOKEN",
    "GH_TOKEN",
)

_CONTROL_CHARS = re.compile(r"[\x00-\x1f\x7f]")


def passthrough_env() -> list[str]:
    """Env var names to forward: every *_API_KEY plus PASSTHROUGH_ENV."""
    names = {key for key in os.environ if key.endswith("_API_KEY")}
    names.update(PASSTHROUGH_ENV)
    return sorted(names)


def info(msg: str) -> None:
    print(f"clankbox: {msg}", file=sys.stderr, flush=True)


def say(msg: str) -> None:
    print(f"clankbox: {msg}")


def print_logo() -> None:
    if sys.stderr.isatty():
        print(LOGO, file=sys.stderr)


def die(msg: str, code: int = 1) -> NoReturn:
    print(f"clankbox: {msg}", file=sys.stderr)
    raise SystemExit(code)


def need_podman() -> str:
    if os.geteuid() == 0:
        die("refusing to run as root; use rootless podman as an unprivileged user")
    path = shutil.which("podman")
    if not path:
        die("podman not found")
    result = run(
        [path, "info", "--format", "{{.Host.Security.Rootless}}"],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to query podman info\n{detail}")
    rootless = (result.stdout or "").strip().lower()
    if rootless != "true":
        die(
            "podman is not rootless for this connection; "
            "clankbox requires rootless podman"
        )
    return path


def run(
    args: list[str],
    *,
    check: bool = True,
    capture: bool = False,
    quiet: bool = False,
) -> subprocess.CompletedProcess[str]:
    kwargs: dict = {}
    if capture:
        kwargs["capture_output"] = True
        kwargs["text"] = True
    if quiet:
        kwargs["stdout"] = subprocess.DEVNULL
        kwargs["stderr"] = subprocess.DEVNULL
    return subprocess.run(args, check=check, **kwargs)


def workdir() -> Path:
    return Path.cwd().resolve()


def _is_under(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def guard_workspace(directory: Path) -> None:
    """Refuse to sandbox directories that would expose the host broadly."""
    if _CONTROL_CHARS.search(str(directory)):
        die(f"refusing to run in {directory!s}: path contains control characters")
    if ":" in str(directory):
        die(
            f"refusing to run in {directory}: path contains ':' "
            f"which breaks container mount syntax"
        )

    home = Path.home().resolve()
    if directory == Path("/"):
        die("refusing to run in filesystem root")
    if directory == home:
        die(f"refusing to run in home directory ({home}); cd into a project first")
    if _is_under(home, directory) and directory != home:
        die(
            f"refusing to run in {directory}, which contains your home directory "
            f"({home}); cd into a project first"
        )

    # Refuse to sandbox the launcher source tree when running from a checkout.
    if directory == SCRIPT_DIR or _is_under(SCRIPT_DIR, directory):
        if (SCRIPT_DIR / "clankbox").exists() or SCRIPT_PATH.name == "clankbox":
            # Only refuse when this looks like the project checkout, not ~/.local/bin.
            if (SCRIPT_DIR / "README.md").is_file() or (
                SCRIPT_DIR / "Dockerfile"
            ).is_file():
                die(
                    f"refusing to run in {directory}: this path contains the "
                    "clankbox source tree; install a copy outside the workspace "
                    "(install -m 0755 ./clankbox ~/.local/bin/clankbox)"
                )

    uid = os.getuid()
    xdg_runtime = Path(
        os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{uid}")
    ).expanduser()
    xdg_config = Path(
        os.environ.get("XDG_CONFIG_HOME", home / ".config")
    ).expanduser()
    xdg_data = Path(
        os.environ.get("XDG_DATA_HOME", home / ".local/share")
    ).expanduser()
    xdg_state = Path(
        os.environ.get("XDG_STATE_HOME", home / ".local/state")
    ).expanduser()

    sensitive_roots = [
        Path("/proc"),
        Path("/sys"),
        Path("/dev"),
        Path("/run"),
        Path("/etc"),
        home / ".ssh",
        home / ".gnupg",
        home / ".aws",
        home / ".docker",
        home / ".podman",
        home / ".local" / "share" / "containers",
        home / ".local" / "share" / "opencode",
        xdg_runtime,
        xdg_config,
        xdg_data,
        xdg_state,
    ]
    for root in sensitive_roots:
        try:
            resolved = root.resolve()
        except OSError:
            continue
        if directory == resolved or _is_under(directory, resolved):
            die(
                f"refusing to run in sensitive path {directory} "
                f"(under {resolved})"
            )


def container_name(directory: Path) -> str:
    digest = hashlib.sha256(str(directory).encode()).hexdigest()[:12]
    return f"clankbox-{digest}"


def state_directory() -> Path:
    state_home = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state"))
    directory = state_home / "clankbox"
    directory.mkdir(mode=0o700, parents=True, exist_ok=True)
    directory.chmod(0o700)
    return directory


def lock_directory() -> Path:
    directory = state_directory() / "locks"
    directory.mkdir(mode=0o700, parents=True, exist_ok=True)
    directory.chmod(0o700)
    return directory


def empty_ro_file() -> Path:
    path = state_directory() / "empty"
    if not path.exists():
        path.write_bytes(b"")
        path.chmod(0o600)
    return path


@contextmanager
def lock(name: str, mode: int):
    path = lock_directory() / name
    fd = os.open(path, os.O_CREAT | os.O_RDWR | os.O_NOFOLLOW, 0o600)
    try:
        os.fchmod(fd, 0o600)
        fcntl.flock(fd, mode)
        yield
    finally:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)


@contextmanager
def image_lock():
    with lock("image.lock", fcntl.LOCK_EX):
        yield


@contextmanager
def container_lock(directory: Path | None = None):
    global_mode = fcntl.LOCK_EX if directory is None else fcntl.LOCK_SH
    with lock("containers.lock", global_mode):
        if directory is None:
            yield
            return
        digest = hashlib.sha256(str(directory).encode()).hexdigest()[:12]
        with lock(f"container-{digest}.lock", fcntl.LOCK_EX):
            yield


def image_exists() -> bool:
    result = run(["podman", "image", "exists", IMAGE], check=False)
    if result.returncode not in (0, 1):
        die(f"failed to check whether image {IMAGE} exists")
    return result.returncode == 0


def _inspect_not_found(stderr: str, stdout: str) -> bool:
    text = f"{stderr}\n{stdout}".lower()
    return (
        "no such object" in text
        or "no such container" in text
        or "error: no such container" in text
        or "failed to find object" in text
    )


def container_state(name: str) -> str | None:
    result = run(
        ["podman", "inspect", "-f", "{{.State.Status}}", name],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        if _inspect_not_found(result.stderr or "", result.stdout or ""):
            return None
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to inspect container {name}\n{detail}")
    status = (result.stdout or "").strip()
    return status or None


def container_label(name: str, key: str) -> str | None:
    result = run(
        [
            "podman",
            "inspect",
            "-f",
            f'{{{{index .Config.Labels "{key}"}}}}',
            name,
        ],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        if _inspect_not_found(result.stderr or "", result.stdout or ""):
            return None
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to inspect labels on {name}\n{detail}")
    value = (result.stdout or "").strip()
    if not value or value == "<no value>":
        return None
    return value


def require_clankbox_container(name: str, directory: Path | None = None) -> str:
    """Validate ownership labels. Schema may be legacy."""
    state = container_state(name)
    if state is None:
        if directory is None:
            die(f"container {name} disappeared during operation")
        die(f"no container for {directory}; run 'clankbox init' first")
    if container_label(name, LABEL_KEY) != "1":
        die(
            f"container {name} exists but is not a clankbox container; "
            "refusing to use it"
        )
    work = container_label(name, LABEL_WORKDIR)
    if not work:
        die(f"container {name} is missing {LABEL_WORKDIR} label; refusing to use it")
    if directory is not None and work != str(directory):
        die(
            f"container {name} workdir label mismatch "
            f"(label={work!r}, expected={str(directory)!r}); refusing to use it"
        )
    expected = container_name(Path(work))
    if name != expected:
        die(
            f"container {name} name does not match workdir label {work!r}; "
            "refusing to use it"
        )
    return state


def require_owned_container(name: str, directory: Path) -> str:
    """Validate identity labels and current schema."""
    state = require_clankbox_container(name, directory)
    schema = container_label(name, LABEL_SCHEMA)
    if schema != SCHEMA_VERSION:
        die(
            f"container {name} has unsupported schema {schema!r} "
            f"(need {SCHEMA_VERSION}); run 'clankbox rm' then 'clankbox init'"
        )
    return state


def require_removable_container(name: str, directory: Path) -> str:
    """Validate ownership for removal; allow legacy schemas."""
    return require_clankbox_container(name, directory)


def list_clankbox_names(*, all_containers: bool = True) -> list[str]:
    args = ["podman", "ps"]
    if all_containers:
        args.append("-a")
    args.extend(
        [
            "--filter",
            f"label={LABEL_KEY}=1",
            "--format",
            "{{.Names}}",
        ]
    )
    result = run(args, check=False, capture=True)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to list clankbox containers\n{detail}")
    return [line.strip() for line in (result.stdout or "").splitlines() if line.strip()]


def validated_clankbox_names(*, require_current_schema: bool) -> list[str]:
    names = list_clankbox_names(all_containers=True)
    valid: list[str] = []
    for name in names:
        require_clankbox_container(name)
        if require_current_schema:
            schema = container_label(name, LABEL_SCHEMA)
            if schema != SCHEMA_VERSION:
                die(
                    f"container {name} has unsupported schema {schema!r} "
                    f"(need {SCHEMA_VERSION}); remove it with 'clankbox rm' "
                    "from its workdir or 'clankbox rm --all'"
                )
        valid.append(name)
    return valid


def build_image() -> None:
    info(f"building image {IMAGE} (this can take a few minutes)")
    # Secure private context so the embedded Dockerfile never lands at a fixed path.
    ctx = tempfile.mkdtemp(prefix="clankbox.", dir="/tmp")
    try:
        os.chmod(ctx, 0o700)
        dockerfile = Path(ctx) / "Dockerfile"
        dockerfile.write_text(DOCKERFILE, encoding="utf-8")
        os.chmod(dockerfile, 0o600)
        run(
            [
                "podman",
                "build",
                "-t",
                IMAGE,
                "-f",
                str(dockerfile),
                ctx,
            ]
        )
    finally:
        shutil.rmtree(ctx, ignore_errors=True)


def cmd_build(args: list[str]) -> None:
    if wants_help(args):
        die("usage: clankbox build", code=0)
    if args:
        die("build does not accept arguments (try 'clankbox help')")
    need_podman()
    with image_lock():
        build_image()


def ensure_image() -> None:
    with image_lock():
        if not image_exists():
            info(f"image {IMAGE} not found, building it first")
            build_image()


def is_wsl() -> bool:
    try:
        return "microsoft" in Path("/proc/version").read_text().lower()
    except OSError:
        return False


def host_xauthority() -> Path | None:
    env_path = os.environ.get("XAUTHORITY")
    if env_path:
        path = Path(env_path)
        if path.is_file():
            return path
    default = Path.home() / ".Xauthority"
    if default.is_file():
        return default
    return None


def display_uses_unix_socket(display: str) -> bool:
    return display.startswith(":") or display.startswith("unix:")


def require_x11_host() -> str:
    display = os.environ.get("DISPLAY")
    if not display:
        die(
            "DISPLAY is not set. Start an X server (or WSLg), or ssh -Y, and "
            "export DISPLAY before 'clankbox init --x11'"
        )
    if display_uses_unix_socket(display) and not X11_SOCKET_DIR.is_dir():
        die(
            f"X11 socket directory {X11_SOCKET_DIR} not found for DISPLAY={display}. "
            "For local/WSLg displays the host X server must expose that path. "
            "For SSH X11 forwarding use ssh -Y (DISPLAY like localhost:10.0)."
        )
    return display


def x11_exec_env_args() -> list[str]:
    args: list[str] = []
    if display := os.environ.get("DISPLAY"):
        args.extend(["-e", f"DISPLAY={display}"])
    if host_xauthority() is not None:
        args.extend(["-e", "XAUTHORITY=/home/clank/.Xauthority"])
    return args


def sync_xauthority(name: str) -> None:
    xauth = host_xauthority()
    if xauth is None:
        return
    result = run(
        ["podman", "cp", str(xauth), f"{name}:/home/clank/.Xauthority"],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to copy Xauthority into {name}\n{detail}")


def init_features_suffix(*, nvidia: bool, x11: bool) -> str:
    parts: list[str] = []
    if nvidia:
        parts.append("NVIDIA GPU")
    if x11:
        parts.append("X11")
    if not parts:
        return ""
    return " with " + " and ".join(parts)


def _ro_bind(host: Path, dest: str) -> list[str]:
    return ["-v", f"{host}:{dest}:ro,z"]


def _protect_gitdir(git_dir: Path) -> list[str]:
    """Protect executable Git metadata for a normal .git directory."""
    args: list[str] = []
    hooks = git_dir / "hooks"
    if hooks.is_dir() and not hooks.is_symlink():
        args.extend(_ro_bind(hooks, "/workspace/.git/hooks"))
    else:
        args.extend(["--mount", "type=tmpfs,destination=/workspace/.git/hooks"])

    for name in ("config", "config.worktree"):
        path = git_dir / name
        if path.is_file() and not path.is_symlink():
            args.extend(_ro_bind(path, f"/workspace/.git/{name}"))
        else:
            args.extend(_ro_bind(empty_ro_file(), f"/workspace/.git/{name}"))

    info_dir = git_dir / "info"
    info_attrs = info_dir / "attributes"
    if info_attrs.is_file() and not info_attrs.is_symlink():
        args.extend(_ro_bind(info_attrs, "/workspace/.git/info/attributes"))
    elif info_dir.is_dir() and not info_dir.is_symlink():
        args.extend(_ro_bind(empty_ro_file(), "/workspace/.git/info/attributes"))
    else:
        args.extend(["--mount", "type=tmpfs,destination=/workspace/.git/info"])

    # Protect immediate and nested module gitdirs under .git/modules only.
    modules = git_dir / "modules"
    if modules.is_dir() and not modules.is_symlink():
        for dirpath, dirnames, _filenames in os.walk(modules, followlinks=False):
            current = Path(dirpath)
            # Prune heavy Git content directories.
            dirnames[:] = [
                d
                for d in dirnames
                if d not in {"objects", "refs", "logs", "hooks", "info"}
            ]
            if not (current / "HEAD").exists():
                continue
            if not (
                (current / "objects").exists()
                or (current / "refs").exists()
                or (current / "config").exists()
            ):
                continue
            rel = current.relative_to(git_dir).as_posix()
            dest = f"/workspace/.git/{rel}"
            hooks_m = current / "hooks"
            if hooks_m.is_dir() and not hooks_m.is_symlink():
                args.extend(_ro_bind(hooks_m, f"{dest}/hooks"))
            else:
                args.extend(["--mount", f"type=tmpfs,destination={dest}/hooks"])
            for name in ("config", "config.worktree"):
                path = current / name
                if path.is_file() and not path.is_symlink():
                    args.extend(_ro_bind(path, f"{dest}/{name}"))
                else:
                    args.extend(_ro_bind(empty_ro_file(), f"{dest}/{name}"))
    return args


def git_mount_args(directory: Path) -> list[str]:
    """Protect host-executed Git metadata when the workspace root is a normal repo.

    Git is optional. Linked worktrees and submodule checkouts (`.git` file) are
    unsupported for in-container Git; the workspace still mounts normally.
    """
    git_path = directory / ".git"
    try:
        st = git_path.lstat()
    except OSError:
        # Non-git workspace: hide any agent-created .git from the host.
        return ["--mount", "type=tmpfs,destination=/workspace/.git"]

    if stat.S_ISLNK(st.st_mode):
        die(f"refusing symlink .git at {git_path}")

    if stat.S_ISREG(st.st_mode):
        die(
            f"{directory} uses a .git file (linked worktree or submodule checkout). "
            "clankbox supports normal repository roots with a .git directory, "
            "or non-git directories. cd to the main checkout, or use a non-git path."
        )

    if not stat.S_ISDIR(st.st_mode):
        die(f"unsupported .git type at {git_path}")

    return _protect_gitdir(git_path)


def create_container(
    name: str, directory: Path, *, nvidia: bool = False, x11: bool = False
) -> None:
    guard_workspace(directory)
    home = Path.home()
    if ":" in str(home):
        die(f"cannot mount host files: home path contains ':' ({home})")
    display = require_x11_host() if x11 else None
    args: list[str] = [
        "podman",
        "create",
        "--name",
        name,
        "--label",
        f"{LABEL_KEY}=1",
        "--label",
        f"{LABEL_WORKDIR}={directory}",
        "--label",
        f"{LABEL_SCHEMA}={SCHEMA_VERSION}",
        "--workdir",
        "/workspace",
        "--user",
        "1000:1000",
        "--userns",
        "keep-id:uid=1000,gid=1000",
        "--pids-limit",
        os.environ.get("CLANKBOX_PIDS", "512"),
        "--memory",
        os.environ.get("CLANKBOX_MEMORY", "4g"),
        "--memory-swap",
        os.environ.get("CLANKBOX_MEMORY", "4g"),
        "-v",
        f"{directory}:/workspace:rw,Z",
        "-e",
        "HOME=/home/clank",
        "-e",
        f"TERM={os.environ.get('TERM', 'xterm-256color')}",
        "-e",
        "LANG=C.UTF-8",
        "-e",
        "LC_ALL=C.UTF-8",
    ]
    if nvidia:
        args.extend(
            [
                "--device",
                "nvidia.com/gpu=all",
                "--label",
                f"{LABEL_NVIDIA}=1",
            ]
        )
    if x11:
        assert display is not None
        args.extend(
            [
                "--network",
                "host",
                "--label",
                f"{LABEL_X11}=1",
                "-e",
                f"DISPLAY={display}",
            ]
        )
        if X11_SOCKET_DIR.is_dir():
            args.extend(["-v", f"{X11_SOCKET_DIR}:{X11_SOCKET_DIR}:ro"])
        if is_wsl() and WSLG_DIR.is_dir():
            args.extend(["-v", f"{WSLG_DIR}:{WSLG_DIR}:ro"])
        if host_xauthority() is not None:
            args.extend(["-e", "XAUTHORITY=/home/clank/.Xauthority"])
    if colorterm := os.environ.get("COLORTERM"):
        args.extend(["-e", f"COLORTERM={colorterm}"])

    args.extend(git_mount_args(directory))

    gitconfig = home / ".gitconfig"
    if gitconfig.is_file() and not gitconfig.is_symlink():
        args.extend(["-v", f"{gitconfig}:/home/clank/.gitconfig:ro,z"])

    auth = home / ".local/share/opencode/auth.json"
    if auth.is_file() and not auth.is_symlink():
        args.extend(["-v", f"{auth}:/tmp/clankbox-auth.json:ro,z"])

    config = home / ".config/opencode"
    if config.is_dir() and not config.is_symlink():
        args.extend(["-v", f"{config}:/home/clank/.config/opencode:ro,z"])

    args.extend([IMAGE, "sleep", "infinity"])
    info("creating container" + init_features_suffix(nvidia=nvidia, x11=x11))
    result = run(args, check=False, capture=True)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        if nvidia:
            die(
                "failed to create container with GPU access. "
                "Host needs an NVIDIA driver and nvidia-container-toolkit "
                f"with CDI (device nvidia.com/gpu=all).\n{detail}"
            )
        if x11:
            die(
                "failed to create container with X11 access. "
                "Host needs a working X server, WSLg, or ssh -Y with DISPLAY set.\n"
                f"{detail}"
            )
        die(f"failed to create container\n{detail}")


