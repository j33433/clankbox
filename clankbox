def start_container(name: str, *, nvidia: bool = False) -> None:
    result = run(["podman", "start", name], check=False, capture=True)
    if result.returncode == 0:
        return
    detail = (result.stderr or result.stdout or "").strip()
    if nvidia or container_has_nvidia(name):
        die(
            "failed to start container with GPU access. "
            "Host needs an NVIDIA driver and nvidia-container-toolkit "
            f"with CDI (device nvidia.com/gpu=all).\n{detail}"
        )
    die(f"failed to start container {name}\n{detail}")


def ensure_running(name: str, directory: Path) -> None:
    state = require_owned_container(name, directory)
    if state == "paused":
        die(f"container {name} is paused; run 'podman unpause {name}' or recreate it")
    if state not in ("running", "created", "exited", "stopped"):
        die(f"container {name} is in unsupported state {state!r}")
    if state != "running":
        info(f"starting container {name}")
        start_container(name)
        copy_auth_if_present(name)
    if container_has_x11(name):
        sync_xauthority(name)
    if not is_provisioned(name):
        provision(name)
    if container_has_nvidia(name) and not is_nvidia_provisioned(name):
        provision_nvidia(name)
    if container_has_x11(name) and not is_x11_provisioned(name):
        provision_x11(name)


def wants_help(args: list[str]) -> bool:
    return bool(args) and args[0] in ("-h", "--help", "help")


def require_no_extra_args(args: list[str], command: str) -> None:
    if wants_help(args):
        die(f"usage: clankbox {command}", code=0)
    if args:
        die(f"{command} does not accept arguments (try 'clankbox help')")


def parse_all_flag(args: list[str], command: str) -> bool:
    if wants_help(args):
        die(f"usage: clankbox {command} [--all|-a]", code=0)
    if not args:
        return False
    if args in (["--all"], ["-a"]):
        return True
    die(f"unknown {command} option {' '.join(args)!r} (try 'clankbox help')")


def cmd_init(args: list[str]) -> None:
    if wants_help(args):
        die("usage: clankbox init [--nvidia] [--x11]", code=0)
    nvidia = False
    x11 = False
    for arg in args:
        if arg == "--nvidia":
            nvidia = True
        elif arg == "--x11":
            x11 = True
        else:
            die(f"unknown init option {arg!r} (try 'clankbox help')")

    need_podman()
    directory = workdir()
    guard_workspace(directory)
    ensure_image()
    name = container_name(directory)
    with container_lock(directory):
        state = container_state(name)
        if state is None:
            info(f"no container for {directory}, setting one up")
            create_container(name, directory, nvidia=nvidia, x11=x11)
            info("starting container")
            start_result = run(["podman", "start", name], check=False, capture=True)
            if start_result.returncode != 0:
                detail = (start_result.stderr or start_result.stdout or "").strip()
                run(["podman", "rm", "-f", name], check=False, quiet=True)
                if nvidia:
                    die(
                        "failed to start container with GPU access. "
                        "Host needs an NVIDIA driver and nvidia-container-toolkit "
                        f"with CDI (device nvidia.com/gpu=all).\n{detail}"
                    )
                if x11:
                    die(
                        "failed to start container with X11 access. "
                        "Host needs a working X server, WSLg, or ssh -Y "
                        f"with DISPLAY set.\n{detail}"
                    )
                die(f"failed to start container {name}\n{detail}")
            copy_auth_if_present(name)
            if x11:
                sync_xauthority(name)
            provision(name)
            if nvidia:
                provision_nvidia(name)
            if x11:
                provision_x11(name)
            say(
                f"initialized {name}"
                + init_features_suffix(nvidia=nvidia, x11=x11)
            )
            return

        require_owned_container(name, directory)
        has_nvidia = container_has_nvidia(name)
        has_x11 = container_has_x11(name)
        if nvidia and not has_nvidia:
            die(
                f"{name} already exists without GPU access; "
                f"run 'clankbox rm' then 'clankbox init --nvidia'"
            )
        if x11 and not has_x11:
            die(
                f"{name} already exists without X11 access; "
                f"run 'clankbox rm' then 'clankbox init --x11'"
            )

        if state == "paused":
            die(f"container {name} is paused; run 'podman unpause {name}' or recreate it")
        if state != "running":
            info(f"starting container {name}")
            start_container(name, nvidia=has_nvidia)
            copy_auth_if_present(name)

        if has_x11:
            sync_xauthority(name)

        did_work = False
        if not is_provisioned(name):
            provision(name)
            did_work = True
        if has_nvidia and not is_nvidia_provisioned(name):
            provision_nvidia(name)
            did_work = True
        if has_x11 and not is_x11_provisioned(name):
            provision_x11(name)
            did_work = True
        if did_work:
            say(
                f"initialized {name}"
                + init_features_suffix(nvidia=has_nvidia, x11=has_x11)
            )
            return
        say(f"already initialized ({name})")


def exec_in(name: str, command: list[str]) -> None:
    args = [
        "podman",
        "exec",
        "-i",
        "-w",
        "/workspace",
        "-e",
        f"TERM={os.environ.get('TERM', 'xterm-256color')}",
        "-e",
        "LANG=C.UTF-8",
        "-e",
        "LC_ALL=C.UTF-8",
    ]
    if sys.stdin.isatty() and sys.stdout.isatty():
        args.insert(2, "-t")
    if container_has_x11(name):
        sync_xauthority(name)
        args.extend(x11_exec_env_args())
    for key in passthrough_env():
        if os.environ.get(key):
            args.extend(["-e", key])
    args.extend([name, *command])
    os.execvp("podman", args)


def cmd_list(args: list[str]) -> None:
    require_no_extra_args(args, "list")
    need_podman()
    result = run(
        [
            "podman",
            "ps",
            "-a",
            "--filter",
            f"label={LABEL_KEY}=1",
            "--format",
            "{{.Names}}\t{{.Status}}",
        ],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        die(f"failed to list clankbox containers\n{detail}")
    lines = [line for line in (result.stdout or "").splitlines() if line.strip()]
    if not lines:
        say("no clankbox containers")
        return
    print(f"{'NAMES':<24} {'STATUS':<28} WORKDIR")
    for line in lines:
        name, _, status = line.partition("\t")
        work = container_label(name, LABEL_WORKDIR) or ""
        work_disp = _CONTROL_CHARS.sub("?", work)
        print(f"{name:<24} {status:<28} {work_disp}")


def human_size(num: int | float) -> str:
    n = float(num)
    for unit, suffix in (
        (1_000_000_000_000, "T"),
        (1_000_000_000, "G"),
        (1_000_000, "M"),
        (1_000, "K"),
    ):
        if n >= unit:
            value = n / unit
            if value >= 100:
                return f"{value:.0f}{suffix}"
            if value >= 10:
                return f"{value:.1f}{suffix}"
            return f"{value:.2f}{suffix}"
    return f"{int(n)}B"


def cmd_df(args: list[str]) -> None:
    require_no_extra_args(args, "df")
    need_podman()
    names = list_clankbox_names(all_containers=True)

    image_size = 0
    image_inspect = run(
        ["podman", "image", "inspect", "-f", "{{.Size}}", IMAGE],
        check=False,
        capture=True,
    )
    if image_inspect.returncode == 0:
        raw = (image_inspect.stdout or "").strip()
        if raw.isdigit():
            image_size = int(raw)
    elif not _inspect_not_found(image_inspect.stderr or "", image_inspect.stdout or ""):
        detail = (image_inspect.stderr or image_inspect.stdout or "").strip()
        die(f"failed to inspect image {IMAGE}\n{detail}")

    if not names and image_size == 0:
        say("no clankbox containers or image")
        return

    total_rw = 0
    if names:
        print(f"{'NAMES':<24} {'SIZE':>8} {'VIRTUAL':>8}  WORKDIR")
        for name in names:
            inspect = run(
                [
                    "podman",
                    "inspect",
                    "--size",
                    "-f",
                    (
                        "{{.SizeRw}}\t{{.SizeRootFs}}\t"
                        f'{{{{index .Config.Labels "{LABEL_WORKDIR}"}}}}'
                    ),
                    name,
                ],
                check=False,
                capture=True,
            )
            size_rw = 0
            size_root = 0
            work = ""
            if inspect.returncode != 0:
                detail = (inspect.stderr or inspect.stdout or "").strip()
                die(f"failed to inspect {name}\n{detail}")
            parts = (inspect.stdout or "").strip().split("\t")
            if (
                len(parts) >= 1
                and parts[0] not in ("", "<nil>")
                and parts[0].lstrip("-").isdigit()
            ):
                size_rw = int(parts[0])
            if (
                len(parts) >= 2
                and parts[1] not in ("", "<nil>")
                and parts[1].lstrip("-").isdigit()
            ):
                size_root = int(parts[1])
            if len(parts) >= 3:
                work = _CONTROL_CHARS.sub("?", parts[2])
            total_rw += max(size_rw, 0)
            print(
                f"{name:<24} {human_size(max(size_rw, 0)):>8} "
                f"{human_size(max(size_root, 0)):>8}  {work}"
            )
        print()

    print(f"{'ITEM':<32} {'SIZE':>8}")
    if image_size:
        print(f"{IMAGE:<32} {human_size(image_size):>8}")
    if names:
        print(f"{'containers (writable)':<32} {human_size(total_rw):>8}")
        print(
            f"{'total (image + writable)':<32} "
            f"{human_size(image_size + total_rw):>8}"
        )


def cmd_rm(args: list[str]) -> None:
    all_flag = parse_all_flag(args, "rm")
    need_podman()
    if all_flag:
        with container_lock():
            names = validated_clankbox_names(require_current_schema=False)
            if not names:
                say("no clankbox containers to remove")
                return
            run(["podman", "rm", "-f", *names], quiet=True)
            say(f"removed all clankbox containers ({len(names)})")
        return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        require_removable_container(name, directory)
        run(["podman", "rm", "-f", name], quiet=True)
        say(f"removed {name} ({directory})")


def cmd_stop(args: list[str]) -> None:
    all_flag = parse_all_flag(args, "stop")
    need_podman()
    if all_flag:
        with container_lock():
            names = validated_clankbox_names(require_current_schema=True)
            running = [name for name in names if container_state(name) == "running"]
            if not running:
                say("no running clankbox containers")
                return
            info(f"stopping {len(running)} container(s)")
            run(["podman", "stop", *running], quiet=True)
            say(f"stopped all running clankbox containers ({len(running)})")
        return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        state = require_owned_container(name, directory)
        if state == "running":
            info(f"stopping {name}")
            run(["podman", "stop", name], quiet=True)
            say(f"stopped {name}")
        elif state == "paused":
            die(f"{name} is paused; unpause or remove it")
        else:
            say(f"{name} is not running")


def cmd_shell(args: list[str]) -> None:
    if wants_help(args):
        die("usage: clankbox shell [-- cmd...]", code=0)
    need_podman()
    directory = workdir()
    guard_workspace(directory)
    name = container_name(directory)
    with container_lock(directory):
        ensure_running(name, directory)
    if args and args[0] == "--":
        args = args[1:]
    if not args:
        exec_in(name, ["bash", "-l"])
    else:
        exec_in(name, ["bash", "-lc", 'exec "$@"', "bash", *args])


def cmd_enter(args: list[str]) -> None:
    if wants_help(args):
        die("usage: clankbox opencode [args...]", code=0)
    need_podman()
    directory = workdir()
    guard_workspace(directory)
    name = container_name(directory)
    print_logo()
    with container_lock(directory):
        ensure_running(name, directory)
    if not args:
        exec_in(name, ["bash", "-lc", "exec opencode"])
    else:
        exec_in(name, ["bash", "-lc", 'exec opencode "$@"', "bash", *args])


def _update_one(name: str) -> int:
    info(f"updating {name}")
    rc = run(
        [
            "podman",
            "exec",
            "-w",
            "/workspace",
            name,
            "bash",
            "-lc",
            build_provision_script(),
        ],
        check=False,
    ).returncode
    if rc == 0 and container_has_nvidia(name):
        info(f"updating NVIDIA runtime in {name}")
        rc = run(
            [
                "podman",
                "exec",
                "-w",
                "/workspace",
                name,
                "bash",
                "-lc",
                build_nvidia_provision_script(),
            ],
            check=False,
        ).returncode
    if rc == 0 and container_has_x11(name):
        info(f"updating X11 packages in {name}")
        if os.environ.get("DISPLAY"):
            sync_xauthority(name)
        rc = run(
            [
                "podman",
                "exec",
                "-w",
                "/workspace",
                *x11_exec_env_args(),
                name,
                "bash",
                "-lc",
                X11_PROVISION_SCRIPT,
            ],
            check=False,
        ).returncode
    return rc


def cmd_update(args: list[str]) -> None:
    all_flag = parse_all_flag(args, "update")
    need_podman()

    if all_flag:
        with container_lock():
            names = validated_clankbox_names(require_current_schema=True)
            if not names:
                say("no clankbox containers to update")
                return
            started: list[str] = []
            failures = 0
            try:
                for name in names:
                    was_running = container_state(name) == "running"
                    if not was_running:
                        info(f"starting {name}")
                        start_result = run(
                            ["podman", "start", name], check=False, capture=True
                        )
                        if start_result.returncode != 0:
                            say(f"failed to start {name}")
                            failures += 1
                            continue
                        started.append(name)
                        copy_auth_if_present(name)
                    rc = _update_one(name)
                    if rc == 0:
                        say(f"updated {name}")
                    else:
                        say(f"failed to update {name}")
                        failures += 1
            finally:
                for name in started:
                    stop_result = run(
                        ["podman", "stop", name], check=False, capture=True
                    )
                    if stop_result.returncode != 0:
                        say(f"failed to stop {name} after update")
                        failures += 1
            if failures:
                die(f"update failed for {failures} container(s)")
            return

    directory = workdir()
    guard_workspace(directory)
    name = container_name(directory)
    with container_lock(directory):
        ensure_running(name, directory)
        rc = _update_one(name)
        if rc == 0:
            say(f"updated {name}")
        else:
            die(f"failed to update {name}")


def cmd_help() -> None:
    print_logo()
    print(
        """\
clankbox - run opencode in a reusable podman container

Usage:
  clankbox                      Show this help
  clankbox init [options]       Create and provision a container for this dir
                                --nvidia: GPU via CDI + CUDA runtime libs
                                --x11: host display passthrough
  clankbox opencode [args...]   Run opencode (alias: oc)
  clankbox shell [-- cmd...]    Shell into the container (default: bash)
                                use -- to pass flags
  clankbox list                 List all clankbox containers
  clankbox df                   Show disk space used by sandboxes
  clankbox stop [--all|-a]      Stop container for this dir, or all
  clankbox rm [--all|-a]        Remove container for this dir, or all
  clankbox build                Build or rebuild the image (alias: rebuild)
  clankbox update [--all|-a]    Update apt packages and pinned Node.js/opencode
                                in this container, or all containers
                                (also CUDA/X11 extras if those init flags were used)

Behavior:
  - Run 'clankbox init' once per project before other commands
  - Current directory is mounted at /workspace (Git optional)
  - Normal .git directories support staging/commits; hooks/config stay read-only
  - Linked worktrees / submodule checkouts are unsupported for in-container Git
  - One container per absolute path (reused after exit)
  - Network is enabled; common CLI tools are preinstalled
  - Tool versions are pinned in the launcher; reinstall the launcher to bump pins
  - Requires rootless podman
  - init --nvidia needs host NVIDIA driver + nvidia-container-toolkit (CDI)
  - init --x11 needs host DISPLAY (local/WSLg socket or ssh -Y); uses host network"""
    )


def main(argv: list[str]) -> None:
    cmd = argv[0] if argv else ""
    rest = argv[1:]

    if cmd in ("help", "-h", "--help", ""):
        cmd_help()
    elif cmd == "init":
        cmd_init(rest)
    elif cmd == "list":
        cmd_list(rest)
    elif cmd == "df":
        cmd_df(rest)
    elif cmd == "rm":
        cmd_rm(rest)
    elif cmd == "stop":
        cmd_stop(rest)
    elif cmd in ("build", "rebuild"):
        cmd_build(rest)
    elif cmd == "update":
        cmd_update(rest)
    elif cmd == "shell":
        cmd_shell(rest)
    elif cmd in ("opencode", "oc"):
        cmd_enter(rest)
    else:
        die(f"unknown command {cmd!r} (try 'clankbox help')")


if __name__ == "__main__":
    try:
        main(sys.argv[1:])
    except subprocess.CalledProcessError as exc:
        code = exc.returncode
        if code < 0:
            raise SystemExit(128 + (-code)) from None
        raise SystemExit(code) from None
    except KeyboardInterrupt:
        raise SystemExit(130) from None
    except OSError as exc:
        print(f"clankbox: {exc}", file=sys.stderr)
        raise SystemExit(1) from None
