def cmd_update(args: list[str]) -> None:
    need_podman()
    all_flag = args and args[0] in ("--all", "-a")

    if all_flag:
        with container_lock():
            result = run(
                ["podman", "ps", "-aq", "--filter", f"label={LABEL_KEY}=1"],
                check=False,
                capture=True,
            )
            names = (result.stdout or "").split()
            if not names:
                say("no clankbox containers to update")
                return
            started: list[str] = []
            for name in names:
                was_running = container_state(name) == "running"
                if not was_running:
                    info(f"starting {name}")
                    run(["podman", "start", name], quiet=True)
                    started.append(name)
                info(f"updating {name}")
                rc = run(
                    [
                        "podman", "exec", "-t", "-w", "/workspace",
                        name, "bash", "-lc", PROVISION_SCRIPT,
                    ],
                    check=False,
                ).returncode
                if rc == 0 and container_has_nvidia(name):
                    info(f"updating NVIDIA runtime in {name}")
                    rc = run(
                        [
                            "podman", "exec", "-t", "-w", "/workspace",
                            name, "bash", "-lc", NVIDIA_PROVISION_SCRIPT,
                        ],
                        check=False,
                    ).returncode
                if rc == 0 and container_has_x11(name):
                    info(f"updating X11 packages in {name}")
                    sync_xauthority(name)
                    rc = run(
                        [
                            "podman", "exec", "-t", "-w", "/workspace",
                            *x11_exec_env_args(),
                            name, "bash", "-lc", X11_PROVISION_SCRIPT,
                        ],
                        check=False,
                    ).returncode
                if rc == 0:
                    say(f"updated {name}")
                else:
                    say(f"failed to update {name}")
            for name in started:
                run(["podman", "stop", name], quiet=True)
            return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        require_container(name, directory)
        info(f"updating {name}")
        rc = run(
            [
                "podman", "exec", "-t", "-w", "/workspace",
                name, "bash", "-lc", PROVISION_SCRIPT,
            ],
            check=False,
        ).returncode
        if rc == 0 and container_has_nvidia(name):
            info(f"updating NVIDIA runtime in {name}")
            rc = run(
                [
                    "podman", "exec", "-t", "-w", "/workspace",
                    name, "bash", "-lc", NVIDIA_PROVISION_SCRIPT,
                ],
                check=False,
            ).returncode
        if rc == 0 and container_has_x11(name):
            info(f"updating X11 packages in {name}")
            sync_xauthority(name)
            rc = run(
                [
                    "podman", "exec", "-t", "-w", "/workspace",
                    *x11_exec_env_args(),
                    name, "bash", "-lc", X11_PROVISION_SCRIPT,
                ],
                check=False,
            ).returncode
        if rc == 0:
            say(f"updated {name}")
        else:
            say(f"failed to update {name}")


