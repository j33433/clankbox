# Installs/updates the software that is not baked into the image (Node.js,
# opencode) and refreshes apt packages. Used both by 'clankbox init' and
# 'clankbox update', so they share a single source of truth. Keep the marker
# path in sync with PROVISION_MARKER above.
PROVISION_SCRIPT = r"""set -euo pipefail

echo "clankbox: updating Debian packages"
sudo apt-get update
sudo apt-get upgrade -y
sudo apt-get autoremove -y
sudo apt-get clean
sudo rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

echo "clankbox: checking Node.js"
CURRENT=$(node --version 2>/dev/null || echo "none")
# Newest Active/Maintenance LTS release (.lts is false for non-LTS, else a codename).
LATEST=$(curl -fsSL https://nodejs.org/dist/index.json \
    | jq -r '[.[] | select(.lts != false)][0].version')
if [ "$CURRENT" != "$LATEST" ]; then
    echo "clankbox: updating Node.js $CURRENT -> $LATEST"
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64|amd64) NODE_ARCH=x64 ;;
        aarch64|arm64) NODE_ARCH=arm64 ;;
        *) echo "clankbox: unsupported architecture $ARCH for Node.js"; exit 1 ;;
    esac
    NODE_TARBALL="node-${LATEST}-linux-${NODE_ARCH}.tar.xz"
    TMPDIR=$(mktemp -d)
    curl -fsSL -o "$TMPDIR/$NODE_TARBALL" \
        "https://nodejs.org/dist/${LATEST}/${NODE_TARBALL}"
    curl -fsSL -o "$TMPDIR/SHASUMS256.txt" \
        "https://nodejs.org/dist/${LATEST}/SHASUMS256.txt"
    grep " ${NODE_TARBALL}\$" "$TMPDIR/SHASUMS256.txt" > "$TMPDIR/CHECKSUM"
    ( cd "$TMPDIR" && sha256sum -c CHECKSUM )
    sudo tar -xJf "$TMPDIR/$NODE_TARBALL" -C /usr/local --strip-components=1 \
        --exclude='LICENSE' --exclude='README.md'
    rm -rf "$TMPDIR"
    sudo rm -rf /root/.npm /tmp/npm-* || true
else
    echo "clankbox: Node.js already at latest ($CURRENT)"
fi
node --version && npm --version

echo "clankbox: updating opencode"
CURRENT_OC=$(opencode --version 2>/dev/null || echo "none")
if curl -fsSL https://opencode.ai/install | bash; then
    if [ -x /home/clank/.opencode/bin/opencode ]; then
        sudo install -m 0755 /home/clank/.opencode/bin/opencode /usr/local/bin/opencode
        rm -rf /home/clank/.opencode
        NEW_OC=$(opencode --version 2>/dev/null || echo "unknown")
        if [ "$CURRENT_OC" != "$NEW_OC" ]; then
            echo "clankbox: opencode updated ($CURRENT_OC -> $NEW_OC)"
        else
            echo "clankbox: opencode already at latest ($CURRENT_OC)"
        fi
    else
        echo "clankbox: opencode already at latest ($CURRENT_OC)"
    fi
else
    echo "clankbox: opencode install failed (current: $CURRENT_OC)"
    exit 1
fi

# pip is the Debian python3-pip package, so apt-get upgrade above keeps it
# current. Upgrading it separately from PyPI would fight PEP 668 / apt.

touch /home/clank/.clankbox-provisioned
echo "clankbox: done"
"""

# CUDA runtime libraries (not the full toolkit) from NVIDIA's Debian repo.
# Driver userspace and nvidia-smi come from the host via CDI
# (--device nvidia.com/gpu=all). Keep the marker path in sync with
# NVIDIA_PROVISION_MARKER above. CUDA_RUNTIME_STREAM is substituted below.
