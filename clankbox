    bash \\
    bzip2 \\
    ca-certificates \\
    curl \\
    file \\
    findutils \\
    g++ \\
    gawk \\
    git \\
    grep \\
    jq \\
    less \\
    make \\
    nano \\
    openssh-client \\
    patch \\
