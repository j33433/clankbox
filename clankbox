# Extra env vars to forward in addition to any matching *_API_KEY.
PASSTHROUGH_ENV = (
    "GITHUB_TOKEN",
    "GH_TOKEN",
)


def passthrough_env() -> list[str]:
    """Env var names to forward: every *_API_KEY plus PASSTHROUGH_ENV."""
    names = {key for key in os.environ if key.endswith("_API_KEY")}
    names.update(PASSTHROUGH_ENV)
    return sorted(names)


def info(msg: str) -> None:
    """Print a progress message for operations that may be slow."""
    print(f"clankbox: {msg}", file=sys.stderr, flush=True)


def say(msg: str) -> None:
    """Print a uniform result status line."""
    print(f"clankbox: {msg}")


def print_logo() -> None:
    """Print the clankbox logo to stderr."""
    print(LOGO, file=sys.stderr)


def die(msg: str, code: int = 1) -> NoReturn:
    print(f"clankbox: {msg}", file=sys.stderr)
    raise SystemExit(code)


def need_podman() -> str:
    path = shutil.which("podman")
    if not path:
        die("podman not found")
    return path


def run(
    args: list[str],
    *,
    check: bool = True,
    capture: bool = False,
    quiet: bool = False,
) -> subprocess.CompletedProcess[str]:
    kwargs: dict = {}
    if capture:
        kwargs["capture_output"] = True
        kwargs["text"] = True
    if quiet:
        kwargs["stdout"] = subprocess.DEVNULL
        kwargs["stderr"] = subprocess.DEVNULL
    return subprocess.run(args, check=check, **kwargs)


def workdir() -> Path:
    return Path.cwd().resolve()


def guard_workspace(directory: Path) -> None:
    """Refuse to sandbox directories that would expose the host broadly."""
    home = Path.home().resolve()
    if directory == Path("/"):
        die("refusing to run in filesystem root")
    if directory == home:
        die(f"refusing to run in home directory ({home}); cd into a project first")
    try:
        home.relative_to(directory)
    except ValueError:
        pass
    else:
        die(
            f"refusing to run in {directory}, which contains your home directory "
            f"({home}); cd into a project first"
        )


def container_name(directory: Path) -> str:
    digest = hashlib.sha256(str(directory).encode()).hexdigest()[:12]
    return f"clankbox-{digest}"


def lock_directory() -> Path:
    """Return a private, persistent location for process coordination locks."""
    state_home = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state"))
    directory = state_home / "clankbox" / "locks"
    directory.mkdir(mode=0o700, parents=True, exist_ok=True)
    directory.chmod(0o700)
    return directory


@contextmanager
def lock(name: str, mode: int):
    """Hold an advisory lock until the enclosing operation finishes."""
    path = lock_directory() / name
    fd = os.open(path, os.O_CREAT | os.O_RDWR, 0o600)
    try:
        os.fchmod(fd, 0o600)
        fcntl.flock(fd, mode)
        yield
    finally:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)


@contextmanager
def image_lock():
    """Serialize builds of the shared image."""
    with lock("image.lock", fcntl.LOCK_EX):
        yield


@contextmanager
def container_lock(directory: Path | None = None):
    """Serialize lifecycle changes while allowing different workspaces to proceed."""
    global_mode = fcntl.LOCK_EX if directory is None else fcntl.LOCK_SH
    with lock("containers.lock", global_mode):
        if directory is None:
            yield
            return
        digest = hashlib.sha256(str(directory).encode()).hexdigest()[:12]
        with lock(f"container-{digest}.lock", fcntl.LOCK_EX):
            yield


def image_exists() -> bool:
    return run(["podman", "image", "exists", IMAGE], check=False).returncode == 0


def container_state(name: str) -> str | None:
    result = run(
        ["podman", "inspect", "-f", "{{.State.Status}}", name],
        check=False,
        capture=True,
    )
    if result.returncode != 0:
        return None
    status = (result.stdout or "").strip()
    return status or None


def build_image(extra_args: list[str] | None = None) -> None:
    info(f"building image {IMAGE} (this can take a few minutes)")
    run(
        [
            "podman",
            "build",
            "--pull=newer",
            "-t",
            IMAGE,
            "-f",
            str(SCRIPT_DIR / "Dockerfile"),
            str(SCRIPT_DIR),
            *(extra_args or []),
        ]
    )


def cmd_build(args: list[str]) -> None:
    need_podman()
    with image_lock():
        build_image(args)


def ensure_image() -> None:
    with image_lock():
        if not image_exists():
            info(f"image {IMAGE} not found, building it first")
            build_image()


def create_container(name: str, directory: Path) -> None:
    guard_workspace(directory)
    home = Path.home()
    args: list[str] = [
        "podman",
        "create",
        "--name",
        name,
        "--replace",
        "--label",
        f"{LABEL_KEY}=1",
        "--label",
        f"{LABEL_WORKDIR}={directory}",
        "--workdir",
        "/workspace",
        "--user",
        "1000:1000",
        "--userns",
        "keep-id:uid=1000,gid=1000",
        "--pids-limit",
        os.environ.get("CLANKBOX_PIDS", "512"),
        "--memory",
        os.environ.get("CLANKBOX_MEMORY", "4g"),
        "--memory-swap",
        os.environ.get("CLANKBOX_MEMORY", "4g"),
        "-v",
        f"{directory}:/workspace:rw,Z",
        "-e",
        "HOME=/home/clank",
        "-e",
        f"TERM={os.environ.get('TERM', 'xterm-256color')}",
        "-e",
        f"LANG={os.environ.get('LANG', 'C.UTF-8')}",
        "-e",
        f"LC_ALL={os.environ.get('LC_ALL') or os.environ.get('LANG', 'C.UTF-8')}",
    ]
    if colorterm := os.environ.get("COLORTERM"):
        args.extend(["-e", f"COLORTERM={colorterm}"])

    git_dir = directory / ".git"
    git_hooks = git_dir / "hooks"
    git_config = git_dir / "config"
    if git_hooks.is_dir():
        args.extend(["-v", f"{git_hooks}:/workspace/.git/hooks:ro,Z"])
    elif git_dir.is_dir():
        args.extend(
            ["--mount", "type=tmpfs,destination=/workspace/.git/hooks"]
        )
    if git_config.is_file():
        args.extend(["-v", f"{git_config}:/workspace/.git/config:ro,Z"])

    gitconfig = home / ".gitconfig"
    if gitconfig.is_file():
        args.extend(["-v", f"{gitconfig}:/home/clank/.gitconfig:ro,z"])

    auth = home / ".local/share/opencode/auth.json"
    if auth.is_file():
        args.extend(
            ["-v", f"{auth}:/tmp/clankbox-auth.json:ro,z"]
        )

    config = home / ".config/opencode"
    if config.is_dir():
        args.extend(["-v", f"{config}:/home/clank/.config/opencode:ro,z"])

    args.extend([IMAGE, "sleep", "infinity"])
    info("creating container")
    run(args, quiet=True)


def is_provisioned(name: str) -> bool:
    """True if the container has completed provisioning (Node, opencode)."""
    return (
        run(
            ["podman", "exec", name, "test", "-f", PROVISION_MARKER],
            check=False,
            quiet=True,
        ).returncode
        == 0
    )


def provision(name: str) -> None:
    """Install/update in-container software. Raises if provisioning fails."""
    info("provisioning tools (first run, this can take a minute)")
    run(
        [
            "podman", "exec", "-t", "-w", "/workspace",
            name, "bash", "-lc", PROVISION_SCRIPT,
        ]
    )


def copy_auth_if_present(name: str) -> None:
    """Copy staged auth.json to the writable location if the host file was mounted."""
    result = run(
        ["podman", "exec", name, "test", "-f", "/tmp/clankbox-auth.json"],
        check=False,
        quiet=True,
    )
    if result.returncode == 0:
        run(
            ["podman", "exec", name, "cp", "/tmp/clankbox-auth.json",
             "/home/clank/.local/share/opencode/auth.json"],
            quiet=True,
        )


def ensure_container(name: str, directory: Path) -> bool:
    """Ensure a running container and return whether it was provisioned."""
    state = container_state(name)
    if state is None:
        info(f"no container for {directory}, setting one up")
        create_container(name, directory)
        info("starting container")
        run(["podman", "start", name], quiet=True)
        copy_auth_if_present(name)
        provision(name)
        return True
    if state != "running":
        info(f"starting container {name}")
        run(["podman", "start", name], quiet=True)
        copy_auth_if_present(name)
    if not is_provisioned(name):
        provision(name)
        return True
    return False


def exec_in(name: str, command: list[str]) -> None:
    args = [
        "podman",
        "exec",
        "-it",
        "-w",
        "/workspace",
        "-e",
        f"TERM={os.environ.get('TERM', 'xterm-256color')}",
        "-e",
        f"LANG={os.environ.get('LANG', 'C.UTF-8')}",
        "-e",
        f"LC_ALL={os.environ.get('LC_ALL') or os.environ.get('LANG', 'C.UTF-8')}",
    ]
    for key in passthrough_env():
        if os.environ.get(key):
            args.extend(["-e", key])
    args.extend([name, *command])
    os.execvp("podman", args)


def cmd_list() -> None:
    need_podman()
    result = run(
        [
            "podman",
            "ps",
            "-a",
            "--filter",
            f"label={LABEL_KEY}=1",
            "--format",
            "{{.Names}}\t{{.Status}}",
        ],
        check=False,
        capture=True,
    )
    lines = [line for line in (result.stdout or "").splitlines() if line.strip()]
    if not lines:
        say("no clankbox containers")
        return
    print(f"{'NAMES':<24} {'STATUS':<28} WORKDIR")
    for line in lines:
        name, _, status = line.partition("\t")
        work = ""
        inspect = run(
            [
                "podman",
                "inspect",
                "-f",
                f'{{{{index .Config.Labels "{LABEL_WORKDIR}"}}}}',
                name,
            ],
            check=False,
            capture=True,
        )
        if inspect.returncode == 0:
            work = (inspect.stdout or "").strip()
        print(f"{name:<24} {status:<28} {work}")


def cmd_rm(args: list[str]) -> None:
    need_podman()
    all_flag = args and args[0] in ("--all", "-a")
    if all_flag:
        with container_lock():
            result = run(
                ["podman", "ps", "-aq", "--filter", f"label={LABEL_KEY}=1"],
                check=False,
                capture=True,
            )
            ids = (result.stdout or "").split()
            if not ids:
                say("no clankbox containers to remove")
                return
            run(["podman", "rm", "-f", *ids], quiet=True)
            say(f"removed all clankbox containers ({len(ids)})")
        return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        if container_state(name) is None:
            die(f"no container for {directory}")
        run(["podman", "rm", "-f", name], quiet=True)
        say(f"removed {name} ({directory})")


def cmd_stop(args: list[str]) -> None:
    need_podman()
    all_flag = args and args[0] in ("--all", "-a")
    if all_flag:
        with container_lock():
            result = run(
                ["podman", "ps", "-q", "--filter", f"label={LABEL_KEY}=1"],
                check=False,
                capture=True,
            )
            ids = (result.stdout or "").split()
            if not ids:
                say("no running clankbox containers")
                return
            info(f"stopping {len(ids)} container(s)")
            run(["podman", "stop", *ids], quiet=True)
            say(f"stopped all running clankbox containers ({len(ids)})")
        return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        state = container_state(name)
        if state is None:
            die(f"no container for {directory}")
        if state == "running":
            info(f"stopping {name}")
            run(["podman", "stop", name], quiet=True)
            say(f"stopped {name}")
        else:
            say(f"{name} is not running")


def cmd_shell(args: list[str]) -> None:
    need_podman()
    ensure_image()
    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        ensure_container(name, directory)
    if args and args[0] == "--":
        args = args[1:]
    if not args:
        exec_in(name, ["bash", "-l"])
    else:
        exec_in(name, ["bash", "-lc", 'exec "$@"', "bash", *args])


def cmd_enter(args: list[str]) -> None:
    need_podman()
    ensure_image()
    directory = workdir()
    name = container_name(directory)
    print_logo()
    with container_lock(directory):
        ensure_container(name, directory)
    if not args:
        exec_in(name, ["bash", "-lc", "exec opencode"])
    else:
        exec_in(name, ["bash", "-lc", 'exec opencode "$@"', "bash", *args])


PROVISION_MARKER = "/home/clank/.clankbox-provisioned"

# Installs/updates the software that is not baked into the image (Node.js,
# opencode) and refreshes apt packages. Used both to provision a fresh
# container and to update an existing one, so first run and 'clankbox update'
# share a single source of truth. Keep the marker path in sync with
# PROVISION_MARKER above.
PROVISION_SCRIPT = r"""set -euo pipefail

echo "clankbox: updating Debian packages"
sudo apt-get update
sudo apt-get upgrade -y
sudo apt-get autoremove -y
sudo apt-get clean
sudo rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

echo "clankbox: checking Node.js"
CURRENT=$(node --version 2>/dev/null || echo "none")
# Newest Active/Maintenance LTS release (.lts is false for non-LTS, else a codename).
LATEST=$(curl -fsSL https://nodejs.org/dist/index.json \
    | jq -r '[.[] | select(.lts != false)][0].version')
if [ "$CURRENT" != "$LATEST" ]; then
    echo "clankbox: updating Node.js $CURRENT -> $LATEST"
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64|amd64) NODE_ARCH=x64 ;;
        aarch64|arm64) NODE_ARCH=arm64 ;;
        *) echo "clankbox: unsupported architecture $ARCH for Node.js"; exit 1 ;;
    esac
    NODE_TARBALL="node-${LATEST}-linux-${NODE_ARCH}.tar.xz"
    TMPDIR=$(mktemp -d)
    curl -fsSL -o "$TMPDIR/$NODE_TARBALL" \
        "https://nodejs.org/dist/${LATEST}/${NODE_TARBALL}"
    curl -fsSL -o "$TMPDIR/SHASUMS256.txt" \
        "https://nodejs.org/dist/${LATEST}/SHASUMS256.txt"
    grep " ${NODE_TARBALL}\$" "$TMPDIR/SHASUMS256.txt" > "$TMPDIR/CHECKSUM"
    ( cd "$TMPDIR" && sha256sum -c CHECKSUM )
    sudo tar -xJ -C /usr/local --strip-components=1 \
        --exclude='LICENSE' --exclude='README.md' "$TMPDIR/$NODE_TARBALL"
    rm -rf "$TMPDIR"
    sudo rm -rf /root/.npm /tmp/npm-* || true
else
    echo "clankbox: Node.js already at latest ($CURRENT)"
fi
node --version && npm --version

echo "clankbox: updating opencode"
CURRENT_OC=$(opencode --version 2>/dev/null || echo "none")
curl -fsSL https://opencode.ai/install | bash
if [ -x /home/clank/.opencode/bin/opencode ]; then
    sudo install -m 0755 /home/clank/.opencode/bin/opencode /usr/local/bin/opencode
    rm -rf /home/clank/.opencode
    NEW_OC=$(opencode --version 2>/dev/null || echo "unknown")
    if [ "$CURRENT_OC" != "$NEW_OC" ]; then
        echo "clankbox: opencode updated ($CURRENT_OC -> $NEW_OC)"
    else
        echo "clankbox: opencode already at latest ($CURRENT_OC)"
    fi
else
    echo "clankbox: opencode install failed (current: $CURRENT_OC)"
    exit 1
fi

# pip is the Debian python3-pip package, so apt-get upgrade above keeps it
# current. Upgrading it separately from PyPI would fight PEP 668 / apt.

touch /home/clank/.clankbox-provisioned
echo "clankbox: done"
"""


def cmd_update(args: list[str]) -> None:
    need_podman()
    ensure_image()
    all_flag = args and args[0] in ("--all", "-a")

    if all_flag:
        with container_lock():
            result = run(
                ["podman", "ps", "-aq", "--filter", f"label={LABEL_KEY}=1"],
                check=False,
                capture=True,
            )
            names = (result.stdout or "").split()
            if not names:
                say("no clankbox containers to update")
                return
            started: list[str] = []
            for name in names:
                was_running = container_state(name) == "running"
                if not was_running:
                    info(f"starting {name}")
                    run(["podman", "start", name], quiet=True)
                    started.append(name)
                info(f"updating {name}")
                rc = run(
                    [
                        "podman", "exec", "-t", "-w", "/workspace",
                        name, "bash", "-lc", PROVISION_SCRIPT,
                    ],
                    check=False,
                ).returncode
                if rc == 0:
                    say(f"updated {name}")
                else:
                    say(f"failed to update {name}")
            for name in started:
                run(["podman", "stop", name], quiet=True)
            return

    directory = workdir()
    name = container_name(directory)
    with container_lock(directory):
        provisioned = ensure_container(name, directory)
        if provisioned:
            say(f"updated {name}")
            return
        info(f"updating {name}")
        rc = run(
            [
                "podman", "exec", "-t", "-w", "/workspace",
                name, "bash", "-lc", PROVISION_SCRIPT,
            ],
            check=False,
        ).returncode
        if rc == 0:
            say(f"updated {name}")
        else:
            say(f"failed to update {name}")


def cmd_help() -> None:
    print_logo()
    print(
        """\
clankbox - run opencode in a reusable podman container

Usage:
  clankbox                      Start or attach; run opencode in this directory
  clankbox opencode [args...]   Run opencode with arguments (alias: oc)
  clankbox shell [-- cmd...]    Shell into the container (default: bash)
                                use -- to pass flags
  clankbox list                 List all clankbox containers
  clankbox stop [--all|-a]      Stop container for this dir, or all
  clankbox rm [--all|-a]        Remove container for this dir, or all
  clankbox build                Build or rebuild the image (alias: rebuild)
  clankbox update [--all|-a]    Update apt packages, Node.js, and opencode in
                                this container, or all containers
  clankbox help                 Show this help (also: -h, --help)

Behavior:
  - Current directory is mounted at /workspace
  - One container per absolute path (reused after exit)
  - If the container is already running, a new exec session joins it
  - Network is enabled; common CLI tools are preinstalled"""
    )


def main(argv: list[str]) -> None:
    cmd = argv[0] if argv else ""
    rest = argv[1:]

    if cmd in ("help", "-h", "--help"):
        cmd_help()
    elif cmd == "list":
        cmd_list()
    elif cmd == "rm":
        cmd_rm(rest)
    elif cmd == "stop":
        cmd_stop(rest)
    elif cmd in ("build", "rebuild"):
        cmd_build(rest)
    elif cmd == "update":
        cmd_update(rest)
    elif cmd == "shell":
        cmd_shell(rest)
    elif cmd in ("opencode", "oc"):
        cmd_enter(rest)
    elif cmd == "":
        cmd_enter([])
    else:
        die(f"unknown command {cmd!r} (try 'clankbox help')")


if __name__ == "__main__":
    try:
        main(sys.argv[1:])
    except subprocess.CalledProcessError as exc:
        raise SystemExit(exc.returncode) from None
    except KeyboardInterrupt:
        raise SystemExit(130) from None
