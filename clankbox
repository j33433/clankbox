def build_provision_script() -> str:
    node = ARTIFACTS["node"]
    opencode = ARTIFACTS["opencode"]
    return f"""set -euo pipefail

echo "clankbox: updating Debian packages"
sudo apt-get update
sudo apt-get upgrade -y
sudo apt-get autoremove -y

NODE_VERSION="{node["version"]}"
NODE_SHA_X64="{node["sha256"]["x64"]}"
NODE_SHA_ARM64="{node["sha256"]["arm64"]}"
OPENCODE_VERSION="{opencode["version"]}"
OPENCODE_SHA_X64="{opencode["sha256"]["x64"]}"
OPENCODE_SHA_X64_BASELINE="{opencode["sha256"]["x64-baseline"]}"
OPENCODE_SHA_ARM64="{opencode["sha256"]["arm64"]}"

echo "clankbox: checking Node.js (pinned $NODE_VERSION)"
CURRENT=$(node --version 2>/dev/null || echo "none")
if [ "$CURRENT" != "$NODE_VERSION" ]; then
    echo "clankbox: installing Node.js $CURRENT -> $NODE_VERSION"
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64|amd64) NODE_ARCH=x64; NODE_SHA="$NODE_SHA_X64" ;;
        aarch64|arm64) NODE_ARCH=arm64; NODE_SHA="$NODE_SHA_ARM64" ;;
        *) echo "clankbox: unsupported architecture $ARCH for Node.js"; exit 1 ;;
    esac
    NODE_TARBALL="node-${{NODE_VERSION}}-linux-${{NODE_ARCH}}.tar.xz"
    TMPDIR=$(mktemp -d)
    STAGE=$(mktemp -d)
    trap 'rm -rf "$TMPDIR" "$STAGE"' EXIT
    curl -fsSL -o "$TMPDIR/$NODE_TARBALL" \\
        "https://nodejs.org/dist/${{NODE_VERSION}}/${{NODE_TARBALL}}"
    echo "$NODE_SHA  $TMPDIR/$NODE_TARBALL" | sha256sum -c -
    tar -xJf "$TMPDIR/$NODE_TARBALL" -C "$STAGE" --strip-components=1 \\
        --exclude='LICENSE' --exclude='README.md'
    sudo cp -a "$STAGE"/. /usr/local/
    rm -rf "$STAGE" "$TMPDIR"
    trap - EXIT
    sudo rm -rf /root/.npm /tmp/npm-* || true
else
    echo "clankbox: Node.js already at pinned version ($CURRENT)"
fi
node --version && npm --version

echo "clankbox: installing opencode (pinned $OPENCODE_VERSION)"
CURRENT_OC=$(opencode --version 2>/dev/null || echo "none")
if [ "$CURRENT_OC" != "$OPENCODE_VERSION" ]; then
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64|amd64)
            if grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
                OC_ARCH=x64
                OC_SHA="$OPENCODE_SHA_X64"
            else
                OC_ARCH=x64-baseline
                OC_SHA="$OPENCODE_SHA_X64_BASELINE"
            fi
            ;;
        aarch64|arm64) OC_ARCH=arm64; OC_SHA="$OPENCODE_SHA_ARM64" ;;
        *) echo "clankbox: unsupported architecture $ARCH for opencode"; exit 1 ;;
    esac
    OC_TARBALL="opencode-linux-${{OC_ARCH}}.tar.gz"
    TMPDIR=$(mktemp -d)
    trap 'rm -rf "$TMPDIR"' EXIT
    curl -fsSL -o "$TMPDIR/$OC_TARBALL" \\
        "https://github.com/anomalyco/opencode/releases/download/v${{OPENCODE_VERSION}}/${{OC_TARBALL}}"
    echo "$OC_SHA  $TMPDIR/$OC_TARBALL" | sha256sum -c -
    tar -xzf "$TMPDIR/$OC_TARBALL" -C "$TMPDIR"
    if [ ! -x "$TMPDIR/opencode" ]; then
        echo "clankbox: opencode binary missing from archive"
        exit 1
    fi
    sudo install -m 0755 "$TMPDIR/opencode" /usr/local/bin/opencode
    rm -rf "$TMPDIR"
    trap - EXIT
    NEW_OC=$(opencode --version 2>/dev/null || echo "unknown")
    if [ "$NEW_OC" != "$OPENCODE_VERSION" ]; then
        echo "clankbox: opencode version mismatch after install ($NEW_OC)"
        exit 1
    fi
    echo "clankbox: opencode installed ($CURRENT_OC -> $NEW_OC)"
else
    echo "clankbox: opencode already at pinned version ($CURRENT_OC)"
fi
command -v opencode >/dev/null
opencode --version

touch {PROVISION_MARKER}
echo "clankbox: done"
"""


